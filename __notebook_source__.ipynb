import pandas as pd

# 1. Load dataset
df = pd.read_csv("/kaggle/input/datasets/jsphyg/weather-dataset-rattle-package/weatherAUS.csv")

# 2. Fill missing values (important columns)
cols = ['MinTemp', 'MaxTemp', 'Humidity9am', 'Humidity3pm',
        'Pressure9am', 'Pressure3pm', 'WindSpeed9am', 'WindSpeed3pm']

for col in cols:
    df[col] = df[col].fillna(df[col].mean())

# 3. Handle Rain columns
df['RainToday'] = df['RainToday'].fillna('No')
df['RainTomorrow'] = df['RainTomorrow'].fillna('No')

# 4. Convert Yes/No → numbers
df['RainToday'] = df['RainToday'].map({'Yes': 1, 'No': 0})
df['RainTomorrow'] = df['RainTomorrow'].map({'Yes': 1, 'No': 0})

# 5. Select features
X = df[['MinTemp', 'MaxTemp', 'Humidity9am', 'Humidity3pm',
        'Pressure9am', 'Pressure3pm', 'WindSpeed9am', 'WindSpeed3pm']]

y = df['RainTomorrow']

# 6. Split data
from sklearn.model_selection import train_test_split
X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2)

# 7. Train model
from sklearn.ensemble import RandomForestClassifier
model = RandomForestClassifier(n_estimators=100)
model.fit(X_train, y_train)

# 8. Accuracy
print("Accuracy:", model.score(X_test, y_test))
